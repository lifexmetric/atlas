# Atlas / Codebase Visualizer environment
# Copy this file to .env and fill in real values before running the backend.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
ATLAS_APP_URL=http://localhost:3000
ATLAS_API_URL=http://localhost:3001
ATLAS_WORKSPACE_ID=local-dev

# Used by the Next.js frontend when calling the backend.
NEXT_PUBLIC_ATLAS_API_URL=http://localhost:3001
NEXT_PUBLIC_ATLAS_WORKSPACE_ID=local-dev

# ---------------------------------------------------------------------------
# scan-engine / platform
# ---------------------------------------------------------------------------
# Required for scan-engine Claude graph extraction.
ANTHROPIC_API_KEY=sk-ant-...

# Optional encryption key for platform's SQLite key store.
# If omitted, a dev default is used locally. Do not use the default in production.
PLATFORM_SECRET=dev-secret-change-in-production

# ---------------------------------------------------------------------------
# GitHub ingestion
# ---------------------------------------------------------------------------
# Optional for public repositories, required for private repositories and
# higher GitHub API limits. Use a fine-grained token with read-only repo access.
GITHUB_TOKEN=

# Optional allow-list guardrails for local testing. Leave empty to allow any
# GitHub host/repo URL accepted by the backend validator.
GITHUB_ALLOWED_ORGS=

# ---------------------------------------------------------------------------
# Backboard agents and memory
# ---------------------------------------------------------------------------
# Required for real agent-backed scans.
BACKBOARD_API_KEY=
BACKBOARD_BASE_URL=https://app.backboard.io/api

# Optional stable assistant id. If empty, the backend should create/reuse one
# assistant per Atlas workspace and persist the returned assistant id.
BACKBOARD_ASSISTANT_ID=

# Memory mode requested by the backend when running Backboard synthesis.
# Suggested values: Auto, Off
BACKBOARD_MEMORY=Auto

# Memory Pro mode if enabled for the account/workspace.
# Suggested values: Auto, Off
BACKBOARD_MEMORY_PRO=Auto

# Optional model override if the Backboard API/account supports explicit model
# selection. Leave empty to use the Backboard default.
BACKBOARD_MODEL=

# ---------------------------------------------------------------------------
# Persistence
# ---------------------------------------------------------------------------
# SQLite is the default for local/hackathon development.
# If the backend uses Prisma, this path should work directly.
DATABASE_URL=file:./.atlas/atlas.db

# Optional future Postgres example:
# DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas

# Optional. Use only if the backend chooses Redis/BullMQ for async scan jobs.
# For local MVP, an in-process job queue is acceptable.
REDIS_URL=

# Optional object/blob storage for context exports or large scan artifacts.
# Leave empty for local filesystem storage.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Local repo workspace
# ---------------------------------------------------------------------------
# Directory where repos are cloned temporarily during scans.
ATLAS_REPO_TMP_DIR=.atlas/tmp/repos

# Directory where generated context packages can be staged locally.
ATLAS_EXPORT_DIR=.atlas/exports

# ---------------------------------------------------------------------------
# Scan guardrails
# ---------------------------------------------------------------------------
ATLAS_MAX_REPO_SIZE_MB=250
ATLAS_MAX_FILES=20000
ATLAS_MAX_FILE_SIZE_KB=512
ATLAS_SCAN_TIMEOUT_SECONDS=900

# Comma-separated directories ignored by deterministic scanners and Backboard
# document upload.
ATLAS_SCAN_IGNORE_DIRS=node_modules,.git,dist,build,.next,coverage,vendor,tmp

# Comma-separated file globs that should never be uploaded to Backboard.
ATLAS_SECRET_FILE_GLOBS=.env,.env.*,*secret*,*credentials*,*.pem,*.key

# ---------------------------------------------------------------------------
# CORS / auth for local API testing
# ---------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# Optional bearer token for protecting local API endpoints during demos.
# Leave empty to disable local API auth.
ATLAS_API_AUTH_TOKEN=
