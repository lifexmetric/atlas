# ──────────────────────────────────────────────
# Banking System — Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# ── JWT ──────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL: Auth DB (port 5432) ──────────
POSTGRES_AUTH_HOST=localhost
POSTGRES_AUTH_PORT=5432
POSTGRES_AUTH_DB=auth_db
POSTGRES_AUTH_USER=auth_user
POSTGRES_AUTH_PASSWORD=auth_password

# ── PostgreSQL: Bank DB (port 5433) ──────────
POSTGRES_BANK_HOST=localhost
POSTGRES_BANK_PORT=5433
POSTGRES_BANK_DB=bank_db
POSTGRES_BANK_USER=bank_user
POSTGRES_BANK_PASSWORD=bank_password

# ── Redis (port 6379) ─────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── MongoDB (port 27017) ──────────────────────
MONGODB_URI=mongodb://mongo_user:mongo_password@localhost:27017/customers_db?authSource=admin
MONGODB_DB=customers_db

# ── Neo4j (ports 7474/7687) ───────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# ── Kafka (port 9092) ─────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID_FRAUD=fraud-detection-group
KAFKA_GROUP_ID_NOTIFY=notification-group

# ── Kafka Topics ──────────────────────────────
KAFKA_TOPIC_PAYMENT_INITIATED=payment.initiated
KAFKA_TOPIC_PAYMENT_COMPLETED=payment.completed
KAFKA_TOPIC_PAYMENT_FAILED=payment.failed
KAFKA_TOPIC_FRAUD_ALERT=fraud.alert
KAFKA_TOPIC_ACCOUNT_UPDATED=account.updated

# ── Service URLs (internal) ───────────────────
AUTH_SERVICE_URL=http://localhost:8001
ACCOUNTS_SERVICE_URL=http://localhost:8002
PAYMENTS_SERVICE_URL=http://localhost:8003
FRAUD_SERVICE_URL=http://localhost:8004
CUSTOMER_SERVICE_URL=http://localhost:8005
REPORTING_SERVICE_URL=http://localhost:8007

# ── External: SWIFT/ACH Rail ─────────────────
SWIFT_RAIL_URL=http://localhost:9999
SWIFT_RAIL_API_KEY=mock-swift-key

# ── External: SendGrid ────────────────────────
SENDGRID_API_KEY=SG.mock-key
SENDGRID_FROM_EMAIL=noreply@bank.example.com
MOCK_EXTERNAL=true

# ── External: Twilio ─────────────────────────
TWILIO_ACCOUNT_SID=AC_mock
TWILIO_AUTH_TOKEN=mock_token
TWILIO_FROM_NUMBER=+15550000000

# ── Fraud Detection ───────────────────────────
FRAUD_SCORE_THRESHOLD=0.7
